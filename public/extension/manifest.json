{
  "manifest_version": 3,
  "name": "Reachr LinkedIn Connector",
  "version": "1.1",
  "description": "Legg til leads i Reachr direkte fra LinkedIn",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/in/*",
    "http://localhost:3001/*",
    "https://*.reachr.no/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"]
    }
  ]
}
