{
  "manifest_version": 3,
  "name": "Reachr LinkedIn Connector",
  "version": "1.0",
  "description": "Legg til leads i Reachr direkte fra LinkedIn",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://www.linkedin.com/*", "http://localhost:3001/*", "http://localhost:3000/*", "https://*.reachr.no/*"],
  "action": {
    "default_popup": "popup.html"
  }
}
